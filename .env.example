# === LLM Provider Configuration ===

# Global provider: "anthropic" or "ollama" (default: ollama)
QBR_LLM_PROVIDER=ollama

# Per-stage provider override (optional — enables hybrid mode)
# QBR_EXTRACTION_PROVIDER=ollama      # extraction stages (high volume, local)
# QBR_SYNTHESIS_PROVIDER=anthropic    # report synthesis (1 call, higher quality)

# Anthropic API (only needed if using anthropic provider)
# Get your key at: https://console.anthropic.com
# NOTE: Claude.ai subscription ($20/mo) does NOT provide API access!
#       API billing is separate at console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Ollama (default — runs locally, no API key needed)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
