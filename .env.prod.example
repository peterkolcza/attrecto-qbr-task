# Production environment — copy to .env and fill in values

# Domain (used by Caddy for automatic HTTPS)
QBR_DOMAIN=qbr.yourdomain.com

# LLM Provider: "anthropic" or "ollama"
QBR_LLM_PROVIDER=ollama

# Anthropic API (if using provider=anthropic)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Ollama (default — for Oracle VPS with 24GB RAM, gemma4:e2b fits well)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e2b
